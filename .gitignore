# Raw Retrosheet event files (~900MB; reproducible via download_all.sh)
data/raw/

# Intermediate parsed events (~2.4GB; reproducible via build_half_innings.py)
data/events/events_*.csv

# Half-inning aggregations (large, reproducible)
data/events/half_innings_*.parquet

# Per-season parquet (webapp uses the CSV; parquet is just the compute artifact)
data/events/season_war_*.parquet

# Tagged intermediate lookups regenerated by build_dataset.py each run
# (matches e.g. game_park_2026.csv but NOT the legacy game_park.csv).
# rosters_all.csv is the union of all retro .ROS files, only changes when
# a new season's retro is released, and is needed for per-season teams in
# fit_per_season -- so we check it in rather than expect cron to rebuild.
data/events/game_park_*.csv
data/events/rosters_*.csv
!data/events/rosters_all.csv

# Loader fetch caches (Chadwick register, MLB Stats API feed JSON)
data/cache/

# Cron output
refresh.log

# Python
__pycache__/
*.pyc
.venv/
.ipynb_checkpoints/

# Editor
.DS_Store
.idea/
.vscode/

# Claude Code internal state
.claude/
